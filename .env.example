SECRET_KEY=your-secret-key-here
DEBUG=True
DB_NAME=restaurante_db
DB_USER=root
DB_PASSWORD=yourpassword
DB_HOST=localhost
DB_PORT=3306
ALLOWED_HOSTS=localhost,127.0.0.1
